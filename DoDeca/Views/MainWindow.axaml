<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DoDeca.ViewModels"
        xmlns:y="using:Models.NewLibre"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="DoDeca.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp"
        Title="DoDeca">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <Grid>
    <!-- Define rows for the grid -->
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/> <!-- For the panel -->
        <RowDefinition Height="*"/>  <!-- For the existing content -->
    </Grid.RowDefinitions>

    <!-- New panel for the TextBox and Label -->
    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="10">
        <Label Content="Go:" Margin="0,0,5,0" VerticalAlignment="Center"/>
        <TextBox Width="400" Name="NavPathTB" KeyDown="OnTextBoxKeyDown" />
    </StackPanel>

    <!-- Original Grid with SplitterGrid -->
    <Grid Grid.Row="1" ColumnDefinitions="Auto,4,*">
        <Border x:Name="NavPane"
                Grid.Column="0"
                MinWidth="100"
                Background="#eeeeee">
            <ListBox x:Name="QuickLinksLB"
                     SelectionMode="Single"
                     SelectionChanged="QuickLinkChanged"/>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="4"
                      Background="Gray"
                      ResizeDirection="Columns"
                      DragStarted="OnSplitterDragStarted"
                      DragCompleted="OnSplitterDragCompleted"
                      DragDelta="OnSplitterDragDelta"
                      ResizeBehavior="PreviousAndNext"
                      Cursor="SizeWestEast"/>

        <Grid Grid.Column="2">
            <TreeView Name="FileTree" ItemsSource="{Binding AllNodes}" SelectionChanged="TviClick">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}"/>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>
    </Grid>
</Grid>
</Window>
